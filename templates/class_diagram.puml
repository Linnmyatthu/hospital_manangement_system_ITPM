@startuml
!theme plain
left to right direction
skinparam linetype ortho
skinparam dpi 300
skinparam classAttributeIconSize 0
skinparam defaultFontSize 14
skinparam class {
  BackgroundColor White
  BorderColor Black
  FontSize 14
  AttributeFontSize 12
  Padding 10
  MinWidth 200
}
skinparam arrow {
  Color Black
  Thickness 2
  FontSize 12
}
skinparam nodesep 60
skinparam ranksep 80

' ===== Core Entities =====

class Ward {
  + id: int
  + name: String
  + code: String
  + type: String
  + capacity: int
  + occupied: int
  + lead_consultant: String
  + status: String
  + gender_type: String
  + created_at: Timestamp
  + getOccupancy(): float
  + admitPatient(p: Patient): void
  + dischargePatient(p: Patient): void
}

class Team {
  + id: int
  + name: String
  + specialty: String
  + members: int
  + lead: String
  + created_at: Timestamp
}

class Doctor {
  + id: int
  + name: String
  + specialty: String
  + grade: String
  + on_duty: boolean
  + team_id: int
  + ward_id: int
  + pager: String
  + email: String
  + created_at: Timestamp
  + setOnCall(onCall: boolean): void
  + prescribeTreatment(p: Patient, desc: String): Treatment
}

class Patient {
  + id: int
  + name: String
  + dob: String
  + age: int
  + gender: String
  + nhs_number: String
  + phone: String
  + address: String
  + admission_datetime: Timestamp
  + ward_id: int
  + bed: String
  + doctor_id: int
  + diagnosis: String
  + notes: String
  + status: String
  + discharged_at: Timestamp
  + created_at: Timestamp
  + admit(w: Ward, b: String): void
  + discharge(): void
  + transferTo(newWard: Ward, newBed: String): void
}

class Treatment {
  + id: int
  + patient_id: int
  + treatment: String
  + date: Date
  + notes: String
  + created_at: Timestamp
  + recordTreatment(): void
}

class ActivityLog {
  + id: int
  + action_type: String
  + table_name: String
  + record_id: int
  + description: String
  + timestamp: Timestamp
}

class User {
  + id: int
  + username: String
  + password: String
  + role: String
  + created_at: Timestamp
  + login(): boolean
  + logout(): void
}

' ===== Relationships =====

Ward "1" -- "0..*" Patient : contains
Ward "1" -- "0..*" Doctor : employs
Team "1" -- "0..*" Doctor : has
Doctor "1" -- "0..*" Patient : assigned as consultant
Patient "1" -- "0..*" Treatment : receives
Treatment "0..*" -- "1" Patient : belongs to

' ActivityLog references all tables (no strict FK, shown as note)
ActivityLog ..> Patient : logs
ActivityLog ..> Ward : logs
ActivityLog ..> Doctor : logs
ActivityLog ..> Treatment : logs

' Enum-like constraints (using notes)
note right of Ward : gender_type ∈ ['Mixed','Male','Female']\nstatus ∈ ['active','inactive']
note right of Patient : status ∈ ['Active','Discharged','Critical']
note right of Doctor : grade ∈ ['Consultant','ST7 Registrar',…]\non_duty ∈ {0,1}
note right of User : role ∈ ['admin','staff','doctor']

@enduml